{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,

     /* Bundler mode */
    "moduleResolution": "node",
    "isolatedModules": true,
     "moduleDetection": "force",
     "outDir": "dist",

     /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/server/**/*"]
}
